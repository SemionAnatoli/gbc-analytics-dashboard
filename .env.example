# Demo mode for public Vercel review.
# Recommended for employer demos: the dashboard will use mock_orders.json
# and all UI interactions will work without private CRM/Supabase access.
NEXT_PUBLIC_DEMO_MODE=true

# Optional live integrations. Fill these only in a private environment.
RETAILCRM_URL=https://yourdomain.retailcrm.ru
RETAILCRM_API_KEY=your_retailcrm_api_key

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
